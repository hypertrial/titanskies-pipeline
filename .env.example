# TitanSkies v0.3.x local environment.
# Copy to `.env` for local overrides.

DUCKDB_NAME=titanskies.duckdb
# DUCKDB_PATH takes precedence over DUCKDB_NAME.
# DUCKDB_PATH=/absolute/path/to/titanskies.duckdb
# DBT_PROFILES_DIR=/absolute/path/to/dbt/profiles

# NASA Earthdata Login (required for live granule download).
# earthaccess reads ~/.netrc or EARTHDATA_USERNAME / EARTHDATA_PASSWORD.
# Lowercase earthdata_username / earthdata_password are also accepted.
# EARTHDATA_USERNAME=
# EARTHDATA_PASSWORD=

# TEMPO NO2 L3 NRT collection (do not change without product review).
TEMPO_NO2_CMR_CONCEPT_ID=C3685668637-LARC_CLOUD

# Routine discovery window (hours). Backfills use Dagster run config.
TEMPO_NO2_DISCOVERY_LOOKBACK_HOURS=8

# Atomic geography manifest built by scripts/build_region_artifacts.py
TEMPO_GEOGRAPHY_MANIFEST_PATH=artifacts/geo/tempo_geography_artifacts.json

# Raw NetCDF storage.
TEMPO_NO2_RAW_DATA_DIR=data/raw/tempo_no2_nrt
TEMPO_NO2_RAW_RETENTION_DAYS=30

# Schedules are opt-in. Leave disabled in local dev and CI.
TEMPO_NO2_HOURLY_PIPELINE_SCHEDULE_ENABLED=false
